# ═══════════════════════════════════════════════════════════════════════════════
# SmartTax Assist Frontend - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local file to version control!

# ── API Configuration ────────────────────────────────────────────────────────
# Backend API URL
# Development: http://localhost:8000
# Production on Render: https://smarttax-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Environment ──────────────────────────────────────────────────────────────
# Options: development, production
NEXT_PUBLIC_ENVIRONMENT=development
